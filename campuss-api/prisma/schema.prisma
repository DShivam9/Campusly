generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


model User {
  id             String   @id @default(uuid())
  email          String   @unique
  passwordHash   String   @map("password_hash")
  role           String   // student, faculty, admin, alumni
  fullName       String   @map("full_name")
  department     String?
  enrollmentYear Int?     @map("enrollment_year")
  avatarUrl      String?  @map("avatar_url")
  company        String?
  position       String?
  phone          String?
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  enrollments        Enrollment[]
  attendanceRecords  AttendanceRecord[]  @relation("StudentAttendance")
  markedAttendance   AttendanceRecord[]  @relation("MarkedByFaculty")
  gradesReceived     Grade[]             @relation("StudentGrades")
  gradesGiven        Grade[]             @relation("GradedByFaculty")
  organizedEvents    Event[]             @relation("EventOrganizer")
  eventRegistrations EventRegistration[]
  marketplaceListings MarketplaceListing[]
  serviceRequests    ServiceRequest[]    @relation("StudentRequests")
  handledRequests    ServiceRequest[]    @relation("HandledByAdmin")
  notifications      Notification[]
  taughtCourses      Course[]            @relation("FacultyCourses")
  borrowedBooks      LibraryBook[]       @relation("BookBorrower")
  feeRecords         FeeRecord[]
  timetableEntries   TimetableEntry[]    @relation("TimetableStudent")
  sentMessages       Message[]           @relation("SentMessages")
  receivedMessages   Message[]           @relation("ReceivedMessages")

  @@map("users")
}

model Course {
  id           String  @id @default(uuid())
  code         String  @unique
  name         String
  facultyId    String? @map("faculty_id")
  department   String?
  credits      Int     @default(3)
  semester     Int?
  academicYear String? @map("academic_year")

  faculty      User?   @relation("FacultyCourses", fields: [facultyId], references: [id])
  enrollments  Enrollment[]
  attendanceRecords AttendanceRecord[]
  grades       Grade[]
  timetableEntries  TimetableEntry[]

  @@map("courses")
}

model Enrollment {
  id        String @id @default(uuid())
  studentId String @map("student_id")
  courseId   String @map("course_id")

  student   User   @relation(fields: [studentId], references: [id])
  course    Course @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
  @@map("enrollments")
}

model AttendanceRecord {
  id        String   @id @default(uuid())
  studentId String   @map("student_id")
  courseId   String   @map("course_id")
  date      DateTime @db.Date
  status    String   // present, absent, late
  markedBy  String?  @map("marked_by")

  student   User     @relation("StudentAttendance", fields: [studentId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])
  faculty   User?    @relation("MarkedByFaculty", fields: [markedBy], references: [id])

  @@map("attendance_records")
}

model Grade {
  id        String  @id @default(uuid())
  studentId String  @map("student_id")
  courseId   String  @map("course_id")
  component String  // midterm, final, assignment1, etc.
  score     Float
  maxScore  Float   @map("max_score")
  gradedBy  String? @map("graded_by")

  student   User    @relation("StudentGrades", fields: [studentId], references: [id])
  course    Course  @relation(fields: [courseId], references: [id])
  faculty   User?   @relation("GradedByFaculty", fields: [gradedBy], references: [id])

  @@map("grades")
}

model TimetableEntry {
  id         String @id @default(uuid())
  courseId    String @map("course_id")
  studentId  String @map("student_id")
  dayOfWeek  String @map("day_of_week") // Monday, Tuesday, etc.
  startTime  String @map("start_time")  // "09:00"
  endTime    String @map("end_time")    // "10:00"
  room       String
  type       String @default("lecture") // lecture, lab, tutorial

  course     Course @relation(fields: [courseId], references: [id])
  student    User   @relation("TimetableStudent", fields: [studentId], references: [id])

  @@map("timetable_entries")
}

model LibraryBook {
  id         String   @id @default(uuid())
  title      String
  author     String
  isbn       String   @unique
  status     String   @default("available") // available, issued, overdue
  copies     Int      @default(1)
  borrowerId String?  @map("borrower_id")
  dueDate    DateTime? @map("due_date")
  category   String?

  borrower   User?    @relation("BookBorrower", fields: [borrowerId], references: [id])

  @@map("library_books")
}

model FeeRecord {
  id        String   @id @default(uuid())
  studentId String   @map("student_id")
  item      String
  amount    Float
  status    String   @default("pending") // paid, pending, overdue
  dueDate   DateTime? @map("due_date")
  paidAt    DateTime? @map("paid_at")
  method    String?  // UPI, Net Banking, Card
  txnRef    String?  @map("txn_ref")
  semester  String?

  student   User     @relation(fields: [studentId], references: [id])

  @@map("fee_records")
}

model BusRoute {
  id        String @id @default(uuid())
  routeCode String @map("route_code")
  routeName String @map("route_name")
  stops     Json   // [{name, time, order}]
  schedule  Json   // [{departure_time, frequency_minutes}]

  buses     Bus[]

  @@map("bus_routes")
}

model Bus {
  id           String @id @default(uuid())
  registration String @unique
  routeId      String @map("route_id")
  capacity     Int
  driverName   String? @map("driver_name")
  driverPhone  String? @map("driver_phone")

  route        BusRoute @relation(fields: [routeId], references: [id])
  locations    BusLocation[]

  @@map("buses")
}

model BusLocation {
  id           String   @id @default(uuid())
  busId        String   @map("bus_id")
  lat          Float
  lng          Float
  currentStop  String?  @map("current_stop")
  nextStop     String?  @map("next_stop")
  occupancyPct Int?     @map("occupancy_pct")
  recordedAt   DateTime @default(now()) @map("recorded_at")

  bus          Bus      @relation(fields: [busId], references: [id])

  @@map("bus_locations")
}

model Event {
  id               String   @id @default(uuid())
  title            String
  description      String?
  venue            String?
  startsAt         DateTime @map("starts_at")
  endsAt           DateTime? @map("ends_at")
  organizerId      String?  @map("organizer_id")
  category         String?  // academic, cultural, sports, workshop, seminar
  registrationOpen Boolean  @default(true) @map("registration_open")
  maxAttendees     Int?     @map("max_attendees")

  organizer        User?    @relation("EventOrganizer", fields: [organizerId], references: [id])
  registrations    EventRegistration[]

  @@map("events")
}

model EventRegistration {
  id           String   @id @default(uuid())
  eventId      String   @map("event_id")
  userId       String   @map("user_id")
  registeredAt DateTime @default(now()) @map("registered_at")

  event        Event    @relation(fields: [eventId], references: [id])
  user         User     @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
  @@map("event_registrations")
}

model MarketplaceListing {
  id          String   @id @default(uuid())
  sellerId    String   @map("seller_id")
  title       String
  description String?
  price       Float
  category    String?
  condition   String?  // new, like_new, good, fair
  status      String   @default("pending") // pending, approved, rejected
  imageUrls   Json     @default("[]") @map("image_urls")
  isSold      Boolean  @default(false) @map("is_sold")
  createdAt   DateTime @default(now()) @map("created_at")

  seller      User     @relation(fields: [sellerId], references: [id])

  @@map("marketplace_listings")
}

model ServiceRequest {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  type        String   // bonafide, transcript, library_card, maintenance, it_support, hostel
  description String?
  status      String   @default("pending") // pending, processing, completed, rejected
  priority    String   @default("medium")  // low, medium, high, urgent
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  handledBy   String?  @map("handled_by")

  student     User     @relation("StudentRequests", fields: [studentId], references: [id])
  handler     User?    @relation("HandledByAdmin", fields: [handledBy], references: [id])

  @@map("service_requests")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  title     String
  body      String?
  type      String   @default("info") // info, warning, success, error
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Message {
  id         String   @id @default(uuid())
  senderId   String   @map("sender_id")
  receiverId String   @map("receiver_id")
  content    String
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")

  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@map("messages")
}
